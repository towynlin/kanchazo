{
  "name": "kanchazo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && esbuild server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=server.js --packages=external",
    "start": "NODE_ENV=production node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "lint": "eslint . && tsc --noEmit && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "libphonenumber-js": "^1.13.8",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/cookie": "^1.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
