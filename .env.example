# Database
DATABASE_URL=postgres://kanchazo:kanchazo@localhost:5432/kanchazo

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# SMS provider: "logger" | "twilio"
SMS_PROVIDER=logger

# Twilio (only needed when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email provider: "logger" | "resend"
EMAIL_PROVIDER=logger

# Resend (only needed when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=Kanchazo
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# System admin bootstrap phone (E.164)
ADMIN_PHONE=+15555550100

# Node environment
NODE_ENV=development
