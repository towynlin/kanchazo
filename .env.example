# Database
DATABASE_URL=postgres://kanchazo:kanchazo@localhost:5432/kanchazo

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# SMS provider: "logger" (default) | "twilio"
# Set SMS_PROVIDER=twilio + Twilio creds in your environment or Fly secrets
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email provider: "logger" (default) | "resend"
# Set EMAIL_PROVIDER=resend + RESEND_API_KEY in your environment or Fly secrets
RESEND_API_KEY=

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=Kanchazo
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# System admin bootstrap phone (E.164)
ADMIN_PHONE=+15555550100

# Node environment
NODE_ENV=development
